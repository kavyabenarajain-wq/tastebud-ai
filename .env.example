# ── Orchestrator (the art-director brain) ────────────────────────────────────
# Provider precedence: Anthropic > OpenAI platform > Azure. Set ANTHROPIC_API_KEY
# for claude-sonnet-4-6 (spec), or OPENAI_API_KEY to run the brain on api.openai.com,
# otherwise it falls back to the Azure deployment below.
AZURE_OPENAI_ENDPOINT=https://<resource>.services.ai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.5-1
# ANTHROPIC_API_KEY=            # add to switch the orchestrator to claude-sonnet-4-6
# OPENAI_API_KEY=              # add to run the brain (and image gen) on the OpenAI platform
# OPENAI_MODEL=gpt-5.5         # chat model id on your OpenAI account (set to whatever it exposes)

# ── Image renderer ───────────────────────────────────────────────────────────
# Precedence: Higgsfield > OpenAI (gpt-image-1) > Gemini > mock. With OPENAI_API_KEY
# set, shots render via gpt-image-1 image-edits, preserving the uploaded product.
GEMINI_API_KEY=
# HIGGSFIELD_API_KEY=           # add to render with Higgsfield instead
# OPENAI_IMAGE_MODEL=gpt-image-1.5   # default; ≈3× faster than gpt-image-1 with better fidelity
# OPENAI_IMAGE_QUALITY=medium        # low | medium | high | auto — bump to high for a final hero render
# To render images on AZURE instead of the OpenAI platform: deploy an image model
# (e.g. gpt-image-1.5) in your Azure resource and set its deployment name here. It
# reuses AZURE_OPENAI_ENDPOINT + AZURE_OPENAI_API_KEY and takes precedence over OpenAI.
# AZURE_IMAGE_DEPLOYMENT=gpt-image-1.5
# IMAGE_PROVIDER=gemini         # gemini | higgsfield (auto-picks higgsfield if its key is set)

# ── Open-source models (Replicate) ───────────────────────────────────────────
# Set this to light up the OPEN-SOURCE path. When present it ALSO becomes the primary
# image renderer for single-product shoots: FLUX.1 Kontext [dev] — fast (~2-8s vs
# gpt-image's 21-44s) image-conditioned editing that keeps the product faithful.
# (Model/multi-product/reference frames fall back to OpenAI/Azure/Gemini automatically.)
# Also powers: real super-resolution, background cutout, relighting, instruction edits.
# REPLICATE_API_TOKEN=
# IMAGE_PROVIDER=replicate                                    # force the open-source renderer
# REPLICATE_RENDER_MODEL=qwen/qwen-image-edit                 # Apache-2.0, best legible label text (recommended); or black-forest-labs/flux-kontext-dev (non-commercial weights)
# REPLICATE_IMAGE_INPUT_KEY=                                  # override the input-image field name if a pinned build differs (Kontext=input_image, Qwen=image, auto-detected)
# Model ids are overridable (pin a version or swap to a commercial-safe alternative):
# REPLICATE_UPSCALE_MODEL=nightmareai/real-esrgan      # or a SUPIR / clarity-upscaler slug
# REPLICATE_BG_MODEL=men1scus/birefnet                 # BiRefNet (MIT) matting / cutout
# REPLICATE_RELIGHT_MODEL=zsxkib/ic-light              # IC-Light relighting
# REPLICATE_EDIT_MODEL=black-forest-labs/flux-kontext-pro  # or qwen/qwen-image-edit (Apache-2.0)

# ── Optional ─────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# GOOGLE_VEO_API_KEY=
